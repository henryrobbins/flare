# Modal-specific variant of the FLARE agent image.
#
# Modal's image builder runs (and runs the resulting container) as root and
# silently ignores `USER` instructions. The canonical local-Docker image
# (packages/milp_flare/.../assets/docker/Dockerfile) is built around a non-root
# `agent` user; that design does not survive on Modal. This Dockerfile is the
# root-only equivalent: every tool is installed to a global location that is on
# PATH for root, so there is no dependence on a per-user HOME.
#
# Claude Code refuses to run as root, so the *runtime* agent invocation must set
# IS_SANDBOX=1 (handled by the sandbox runner, not this image).
#
# Build context is the milp_flare `assets/` dir (same as the canonical image),
# so the COPY paths below resolve against `lean/` and `docker/`.

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# ripgrep is recommended for lean_local_search in lean-lsp-mcp.
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        unzip \
        build-essential \
        python3 \
        python3-pip \
        pipx \
        ripgrep \
    && rm -rf /var/lib/apt/lists/*

# Node 20 + agent CLIs (Claude Code, Codex, OpenCode), installed globally.
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
 && apt-get install -y --no-install-recommends nodejs \
 && npm install -g @anthropic-ai/claude-code @openai/codex opencode-ai \
 && rm -rf /var/lib/apt/lists/*

# elan + Lean toolchain, installed to a global ELAN_HOME (not a user HOME) so
# `lake`/`lean` are on PATH for root. `--default-toolchain none` lets the
# lean-toolchain file pin the version on the first `lake` invocation below.
ENV ELAN_HOME=/opt/elan
RUN curl https://raw.githubusercontent.com/leanprover/elan/master/elan-init.sh -sSf \
        | sh -s -- -y --default-toolchain none --no-modify-path

# pipx tools (lean-lsp-mcp for the MCP server, uv for `uvx`) to global dirs so
# their entrypoints land on PATH regardless of user.
ENV PIPX_HOME=/opt/pipx \
    PIPX_BIN_DIR=/usr/local/bin
RUN pipx install lean-lsp-mcp \
 && pipx install uv

ENV PATH="/opt/elan/bin:${PATH}"

WORKDIR /workspace

# Lake project skeleton (Common.lean, lakefile, lean-toolchain, manifest).
COPY lean/ /workspace/

# Pre-fetch mathlib oleans for the pinned toolchain (also installs the
# toolchain, since elan was set up with --default-toolchain none).
RUN lake exe cache get

# Pre-build Common so its olean is warm in /workspace/.lake/build/.
RUN lake build Common

# The runner script: source the harness-rendered agent.sh, then run the
# post-hoc lake compile check and write result.json + compile_log. Unlike the
# canonical image, this is NOT set as the ENTRYPOINT: a Modal Sandbox runs the
# image entrypoint as its main process at creation time, which would fire before
# we've populated /workspace/wd. Instead the sandbox runner invokes it
# explicitly with `sb.exec("/usr/local/bin/run-agent")` once wd is in place.
COPY docker/entrypoint.sh /usr/local/bin/run-agent
RUN chmod +x /usr/local/bin/run-agent
