{
    "sandbox": {
        "enabled": false
    },
    "permissions": {
        "allow": [
            "Skill(lean4:lean4)",
            "Skill(lean-milp-formulation)",
            "Skill(lean-milp-reformulation)",
            "mcp__lean-lsp__*",
            "ToolSearch",
            "Bash(lake env lean:*)",
            "Bash(lake build:*)",
            "Bash(ls ./*)",
            "Bash(find ./*)",
            "Bash(cat ./*)",
            "Bash(head ./*)",
            "Bash(tail ./*)",
            "Bash(less ./*)",
            "Bash(more ./*)",
            "Bash(bat ./*)",
            "Read(./*)",
            "Glob(./*)",
            "Edit(./*)",
            "Write(./*)"
