{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": "deny",
    "webfetch": "deny",
    "websearch": "deny",
    "task": "deny",
    "doom_loop": "deny",
    "read": {
      "*": "deny",
      "<<WD_ABS>>/**": "allow",
      "~/.elan/settings.toml": "allow"
    },
    "edit": {
      "*": "deny",
      "<<WD_ABS>>/**": "allow"
    },
    "glob": {
      "*": "deny",
      "<<WD_ABS>>/**": "allow"
    },
    "grep": {
      "*": "deny",
      "<<WD_ABS>>/**": "allow"
    },
    "skill": {
      "*": "deny",
      "lean-milp-formulation": "allow",
      "lean-milp-reformulation": "allow"
    },
    "bash": {
      "*": "deny",
      "lake env lean *": "allow",
      "lake build *": "allow",
      "ls ./*": "allow",
      "find ./*": "allow",
      "cat ./*": "allow",
      "head ./*": "allow",
      "tail ./*": "allow",
      "less ./*": "allow",
      "more ./*": "allow",
      "bat ./*": "allow"
    },
    "lsp": "allow"
  },
  "mcp": {
    "lean-lsp": {
      "type": "local",
      "command": ["uvx", "lean-lsp-mcp"],
      "enabled": true
    }
  }
}
